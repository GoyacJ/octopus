{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/runtime/trigger-delivery.schema.json",
  "title": "TriggerDelivery",
  "type": "object",
  "description": "Slice 3 shared contract for individual trigger deliveries with dedupe, retry, and recovery semantics.",
  "properties": {
    "id": { "type": "string" },
    "trigger_id": { "type": "string" },
    "run_id": {
      "type": ["string", "null"]
    },
    "status": { "$ref": "https://octopus.local/schemas/runtime/trigger-delivery-status.schema.json" },
    "dedupe_key": { "type": "string" },
    "payload": {},
    "attempt_count": {
      "type": "integer",
      "minimum": 0
    },
    "last_error": {
      "type": ["string", "null"]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "required": [
    "id",
    "trigger_id",
    "run_id",
    "status",
    "dedupe_key",
    "payload",
    "attempt_count",
    "last_error",
    "created_at",
    "updated_at"
  ],
  "additionalProperties": false
}
