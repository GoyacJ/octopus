{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/observe/trace-record.schema.json",
  "title": "TraceRecord",
  "type": "object",
  "description": "Slice 1 shared contract for trace records that capture the orchestration and execution path for a run.",
  "properties": {
    "id": { "type": "string" },
    "workspace_id": { "type": "string" },
    "project_id": { "type": "string" },
    "run_id": { "type": "string" },
    "task_id": { "type": "string" },
    "stage": {
      "type": "string",
      "enum": [
        "task_intake",
        "trigger_delivery",
        "governance_evaluation",
        "run_orchestrator",
        "execution_action",
        "artifact_store",
        "knowledge_recall",
        "knowledge_capture",
        "knowledge_promotion"
      ]
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "required": [
    "id",
    "workspace_id",
    "project_id",
    "run_id",
    "task_id",
    "stage",
    "attempt",
    "message",
    "created_at"
  ],
  "additionalProperties": false
}
