{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MemoryThreatDetectedEvent",
  "type": "object",
  "required": [
    "action",
    "at",
    "category",
    "content_hash",
    "direction",
    "pattern_id",
    "session_id",
    "severity"
  ],
  "properties": {
    "action": {
      "$ref": "#/definitions/ThreatAction"
    },
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "category": {
      "$ref": "#/definitions/ThreatCategory"
    },
    "content_hash": {
      "$ref": "#/definitions/ContentHash"
    },
    "direction": {
      "$ref": "#/definitions/ThreatDirection"
    },
    "pattern_id": {
      "type": "string"
    },
    "provider_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "run_id": {
      "anyOf": [
        {
          "$ref": "#/definitions/TypedUlid"
        },
        {
          "type": "null"
        }
      ]
    },
    "session_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "severity": {
      "$ref": "#/definitions/Severity"
    }
  },
  "definitions": {
    "ContentHash": {
      "type": "array",
      "items": {
        "type": "integer",
        "format": "uint8",
        "minimum": 0.0
      },
      "maxItems": 32,
      "minItems": 32
    },
    "Severity": {
      "type": "string",
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "ThreatAction": {
      "type": "string",
      "enum": [
        "warn",
        "redact",
        "block"
      ]
    },
    "ThreatCategory": {
      "type": "string",
      "enum": [
        "prompt_injection",
        "exfiltration",
        "backdoor",
        "credential",
        "malicious",
        "special_token"
      ]
    },
    "ThreatDirection": {
      "type": "string",
      "enum": [
        "on_write",
        "on_recall"
      ]
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
