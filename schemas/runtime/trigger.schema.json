{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/runtime/trigger.schema.json",
  "title": "Trigger",
  "type": "object",
  "description": "Slice 3 shared contract for trigger definitions that start automation deliveries.",
  "properties": {
    "id": { "type": "string" },
    "automation_id": { "type": "string" },
    "trigger_type": {
      "type": "string",
      "const": "manual_event"
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "required": ["id", "automation_id", "trigger_type", "created_at", "updated_at"],
  "additionalProperties": false
}
