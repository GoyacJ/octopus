{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/governance/capability-visibility.schema.json",
  "title": "CapabilityVisibility",
  "type": "object",
  "description": "GA minimum-surface shared contract that explains why a capability is visible in the current project scope.",
  "properties": {
    "descriptor": {
      "$ref": "https://octopus.local/schemas/governance/capability-descriptor.schema.json"
    },
    "scope_ref": {
      "type": "string",
      "minLength": 1
    },
    "visibility": {
      "type": "string",
      "const": "visible"
    },
    "reason_code": {
      "type": "string",
      "const": "project_scope_grant_active"
    },
    "explanation": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "descriptor",
    "scope_ref",
    "visibility",
    "reason_code",
    "explanation"
  ],
  "additionalProperties": false
}
