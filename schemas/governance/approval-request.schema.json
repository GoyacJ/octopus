{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/governance/approval-request.schema.json",
  "title": "ApprovalRequest",
  "type": "object",
  "description": "GA foundation placeholder shared contract for approval requests.",
  "properties": {
    "id": { "type": "string" },
    "run_id": { "type": "string" },
    "status": { "$ref": "https://octopus.local/schemas/governance/approval-request-status.schema.json" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "required": ["id", "run_id", "status"],
  "additionalProperties": true
}
