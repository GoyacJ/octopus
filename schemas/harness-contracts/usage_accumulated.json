{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UsageAccumulatedEvent",
  "type": "object",
  "required": [
    "at",
    "session_id",
    "usage"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "run_id": {
      "anyOf": [
        {
          "$ref": "#/definitions/TypedUlid"
        },
        {
          "type": "null"
        }
      ]
    },
    "session_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "usage": {
      "$ref": "#/definitions/UsageSnapshot"
    }
  },
  "definitions": {
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    },
    "UsageSnapshot": {
      "type": "object",
      "required": [
        "cache_read_tokens",
        "cache_write_tokens",
        "cost_micros",
        "input_tokens",
        "output_tokens"
      ],
      "properties": {
        "cache_read_tokens": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "cache_write_tokens": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "cost_micros": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "input_tokens": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "output_tokens": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    }
  }
}
