{
  "name": "octopus-desktop",
  "private": true,
  "version": "0.2.5",
  "type": "module",
  "scripts": {
    "dev:ui": "node ../../scripts/run-desktop-ui.mjs dev tauri",
    "build:ui": "node ../../scripts/run-desktop-ui.mjs build tauri",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test --config ./playwright.config.ts",
    "test:e2e:smoke": "playwright test --config ./playwright.config.ts test/e2e/smoke.spec.ts",
    "typecheck": "vue-tsc --noEmit --pretty false"
  },
  "dependencies": {
    "@octopus/assets": "workspace:*",
    "@octopus/schema": "workspace:*",
    "@octopus/ui": "workspace:*",
    "@tauri-apps/api": "^2.10.1",
    "@vee-validate/zod": "^4.15.1",
    "@vue-flow/core": "1.48.2",
    "jszip": "^3.10.1",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.33",
    "vue-i18n": "^11.4.0",
    "vue-router": "^5.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@pinia/testing": "^1.0.3",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.8",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  }
}
