{
  "name": "octopus",
  "private": true,
  "version": "0.2.5",
  "type": "module",
  "scripts": {
    "dev": "pnpm dev:desktop",
    "dev:desktop": "pnpm prepare:desktop-backend:dev && pnpm tauri dev --config apps/desktop/src-tauri/tauri.conf.json",
    "dev:desktop:fresh": "pnpm clean:desktop-shell && pnpm dev:desktop",
    "dev:website": "pnpm -C apps/website dev",
    "build:desktop": "pnpm tauri build --config apps/desktop/src-tauri/tauri.conf.json",
    "build:website": "pnpm -C apps/website generate",
    "prepare:desktop-backend:dev": "node scripts/prepare-desktop-backend.mjs",
    "prepare:desktop-backend:sidecar": "node scripts/prepare-desktop-sidecar.mjs",
    "clean:desktop-shell": "cargo clean -p octopus-desktop-shell",
    "prepare:template-snapshots": "node scripts/prepare-template-snapshots.mjs",
    "dev:web": "node scripts/dev-web.mjs",
    "dev:backend": "node scripts/run-desktop-backend.mjs",
    "build": "pnpm -C apps/desktop build:ui",
    "preview:website": "pnpm -C apps/website preview",
    "test:e2e:desktop": "pnpm -C apps/desktop test:e2e",
    "check:browser-smoke": "pnpm exec playwright test --config apps/desktop/playwright.config.ts apps/desktop/test/e2e/smoke.spec.ts",
    "check:a11y": "pnpm exec playwright test --config apps/desktop/playwright.config.ts apps/desktop/test/e2e/a11y.spec.ts apps/desktop/test/e2e/keyboard-navigation.spec.ts",
    "check:reduced-motion": "pnpm exec playwright test --config apps/desktop/playwright.config.ts apps/desktop/test/e2e/reduced-motion.spec.ts",
    "check:frontend-browser": "pnpm check:browser-smoke && pnpm check:a11y && pnpm check:reduced-motion",
    "check:color-contrast": "node scripts/check-color-contrast.mjs",
    "check:frontend-performance": "node scripts/check-frontend-performance.mjs",
    "check:website": "pnpm -C apps/website typecheck && pnpm -C apps/website test && pnpm -C apps/website generate",
    "check:desktop": "pnpm check:frontend-governance && pnpm check:color-contrast && pnpm -C apps/desktop typecheck && pnpm -C apps/desktop test && pnpm check:frontend-browser && pnpm check:frontend-performance",
    "check:frontend": "pnpm check:desktop && pnpm check:website",
    "check:rust": "pnpm prepare:desktop-backend:sidecar && cargo fmt --all --check && cargo clippy --workspace --all-targets -- -D warnings && cargo test --workspace --locked",
    "check:desktop-release": "pnpm check:desktop && pnpm check:rust && pnpm schema:check && pnpm check:runtime-phase4 && pnpm check:runtime-phase8 && pnpm version:check",
    "check:all": "pnpm check:desktop-release && pnpm check:website",
    "check:frontend-governance": "node scripts/check-frontend-governance.mjs",
    "check:runtime-phase4": "node scripts/check-runtime-phase4-governance.mjs",
    "check:runtime-phase8": "node scripts/check-runtime-phase8-governance.mjs",
    "openapi:bundle": "node scripts/bundle-openapi.mjs",
    "schema:generate": "pnpm openapi:bundle && node scripts/generate-schema.mjs",
    "schema:check:generated": "node scripts/check-schema-governance.mjs",
    "schema:check:routes": "node scripts/check-openapi-route-parity.mjs",
    "schema:check:adapters": "node scripts/check-openapi-adapter-parity.mjs",
    "schema:check": "pnpm schema:check:generated && pnpm schema:check:routes && pnpm schema:check:adapters",
    "version:sync": "node scripts/sync-version.mjs",
    "version:check": "node scripts/check-version-governance.mjs",
    "release:notes": "node scripts/generate-release-notes.mjs",
    "release:notes:preview": "node scripts/generate-release-notes.mjs --channel preview",
    "release:notes:check": "node scripts/generate-release-notes.mjs --require-manual-summary true",
    "release:collect-artifacts": "node scripts/collect-release-artifacts.mjs",
    "release:archive-fragments": "node scripts/archive-release-fragments.mjs",
    "release:collect-metadata": "node scripts/collect-release-metadata.mjs",
    "release:tag:preview": "node scripts/generate-preview-release-tag.mjs",
    "release:verify-artifacts": "node scripts/verify-release-artifacts.mjs",
    "release:generate-update-manifests": "node scripts/generate-update-manifests.mjs",
    "test": "pnpm -C apps/desktop test",
    "tauri": "tauri"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2.10.1",
    "tailwindcss": "^4.2.4",
    "yaml": "^2.8.3"
  }
}
