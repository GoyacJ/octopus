{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/observe/artifact-summary.schema.json",
  "title": "ArtifactSummary",
  "type": "object",
  "description": "GA minimum-surface shared summary contract for artifact rows shown on Run and Artifact pages.",
  "properties": {
    "id": { "type": "string" },
    "run_id": { "type": "string" },
    "task_id": { "type": "string" },
    "artifact_type": {
      "type": "string",
      "const": "execution_output"
    },
    "provenance_source": {
      "type": "string",
      "enum": ["builtin", "mcp_connector"]
    },
    "trust_level": {
      "type": "string",
      "enum": ["trusted", "external_untrusted"]
    },
    "knowledge_gate_status": {
      "type": "string",
      "enum": ["eligible", "blocked_low_trust"]
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "required": [
    "id",
    "run_id",
    "task_id",
    "artifact_type",
    "provenance_source",
    "trust_level",
    "knowledge_gate_status",
    "created_at"
  ],
  "additionalProperties": false
}
