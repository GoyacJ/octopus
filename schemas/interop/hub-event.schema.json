{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/interop/hub-event.schema.json",
  "title": "HubEvent",
  "description": "GA minimum-surface shared transport event contract used by remote SSE and local Tauri event adapters.",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "event_type": {
          "type": "string",
          "const": "run.updated"
        },
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "$ref": "https://octopus.local/schemas/runtime/run-summary.schema.json"
        }
      },
      "required": ["event_type", "sequence", "occurred_at", "payload"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "event_type": {
          "type": "string",
          "const": "inbox.updated"
        },
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "type": "array",
          "items": {
            "$ref": "https://octopus.local/schemas/observe/inbox-item.schema.json"
          }
        }
      },
      "required": ["event_type", "sequence", "occurred_at", "payload"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "event_type": {
          "type": "string",
          "const": "notification.updated"
        },
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "type": "array",
          "items": {
            "$ref": "https://octopus.local/schemas/observe/notification.schema.json"
          }
        }
      },
      "required": ["event_type", "sequence", "occurred_at", "payload"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "event_type": {
          "type": "string",
          "const": "hub.connection.updated"
        },
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "$ref": "https://octopus.local/schemas/interop/hub-connection-status.schema.json"
        }
      },
      "required": ["event_type", "sequence", "occurred_at", "payload"],
      "additionalProperties": false
    }
  ]
}
