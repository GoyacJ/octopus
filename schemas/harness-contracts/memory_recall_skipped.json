{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MemoryRecallSkippedEvent",
  "type": "object",
  "required": [
    "at",
    "reason",
    "run_id",
    "session_id",
    "turn"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "reason": {
      "$ref": "#/definitions/RecallSkipReason"
    },
    "run_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "session_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "turn": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    }
  },
  "definitions": {
    "RecallSkipReason": {
      "type": "string",
      "enum": [
        "no_external_provider",
        "policy_decided_skip",
        "deadline_zero",
        "cancelled"
      ]
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
