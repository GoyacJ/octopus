{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BlobMeta",
  "type": "object",
  "required": [
    "content_hash",
    "created_at",
    "retention",
    "size"
  ],
  "properties": {
    "content_hash": {
      "type": "array",
      "items": {
        "type": "integer",
        "format": "uint8",
        "minimum": 0.0
      },
      "maxItems": 32,
      "minItems": 32
    },
    "content_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "retention": {
      "$ref": "#/definitions/BlobRetention"
    },
    "size": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    }
  },
  "definitions": {
    "BlobRetention": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "tenant_scoped",
            "retain_forever"
          ]
        },
        {
          "type": "object",
          "required": [
            "session_scoped"
          ],
          "properties": {
            "session_scoped": {
              "$ref": "#/definitions/TypedUlid"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "ttl_days"
          ],
          "properties": {
            "ttl_days": {
              "type": "integer",
              "format": "uint32",
              "minimum": 0.0
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
