{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "网易Lobster",
  "version": "0.2.0",
  "identifier": "com.weilaizhihuigu.lobster",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:15420",
    "beforeDevCommand": "pnpm -C apps/desktop dev:ui",
    "beforeBuildCommand": "pnpm prepare:desktop-backend:sidecar && pnpm -C apps/desktop build:ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "网易Lobster",
        "width": 1440,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 820,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "externalBin": [
      "bin/octopus-desktop-backend"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [],
      "pubkey": ""
    }
  }
}
