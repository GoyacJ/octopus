{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/runtime/run-terminate-command.schema.json",
  "title": "RunTerminateCommand",
  "type": "object",
  "description": "Minimum GA run terminate command. Runtime enforces allowed state transitions and requires an audit reason.",
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": ["run_id", "reason"],
  "additionalProperties": false
}
