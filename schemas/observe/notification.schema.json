{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/observe/notification.schema.json",
  "title": "Notification",
  "type": "object",
  "description": "GA foundation placeholder shared contract for user notifications.",
  "properties": {
    "id": { "type": "string" },
    "workspace_id": { "type": "string" },
    "status": { "$ref": "https://octopus.local/schemas/observe/notification-status.schema.json" },
    "dedupe_key": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "required": ["id", "workspace_id", "status"],
  "additionalProperties": true
}
