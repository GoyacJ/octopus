{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "McpConnectionLostEvent",
  "type": "object",
  "required": [
    "at",
    "attempts_so_far",
    "reason",
    "server_id",
    "server_source",
    "terminal"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "attempts_so_far": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "reason": {
      "$ref": "#/definitions/McpConnectionLostReason"
    },
    "server_id": {
      "$ref": "#/definitions/McpServerId"
    },
    "server_source": {
      "$ref": "#/definitions/McpServerSource"
    },
    "session_id": {
      "anyOf": [
        {
          "$ref": "#/definitions/TypedUlid"
        },
        {
          "type": "null"
        }
      ]
    },
    "terminal": {
      "type": "boolean"
    }
  },
  "definitions": {
    "McpConnectionLostReason": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "shutdown"
          ]
        },
        {
          "type": "object",
          "required": [
            "network"
          ],
          "properties": {
            "network": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "auth_failure"
          ],
          "properties": {
            "auth_failure": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "handshake_mismatch"
          ],
          "properties": {
            "handshake_mismatch": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "stdio_process_exited"
          ],
          "properties": {
            "stdio_process_exited": {
              "type": "object",
              "properties": {
                "exit_code": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "format": "int32"
                },
                "signal": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "format": "int32"
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "other"
          ],
          "properties": {
            "other": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "McpServerId": {
      "type": "string"
    },
    "McpServerSource": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "workspace",
            "user",
            "project",
            "policy"
          ]
        },
        {
          "type": "object",
          "required": [
            "plugin"
          ],
          "properties": {
            "plugin": {
              "$ref": "#/definitions/PluginId"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "dynamic"
          ],
          "properties": {
            "dynamic": {
              "type": "object",
              "required": [
                "registered_by"
              ],
              "properties": {
                "registered_by": {
                  "type": "string"
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "managed"
          ],
          "properties": {
            "managed": {
              "type": "object",
              "required": [
                "registry_url"
              ],
              "properties": {
                "registry_url": {
                  "type": "string"
                }
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "PluginId": {
      "type": "string"
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
