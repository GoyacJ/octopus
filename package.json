{
  "name": "octopus",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.11.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "lint": "turbo run lint",
