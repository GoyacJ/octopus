{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "McpToolsListChangedEvent",
  "type": "object",
  "required": [
    "added_count",
    "disposition",
    "received_at",
    "removed_count",
    "server_id"
  ],
  "properties": {
    "added_count": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "disposition": {
      "$ref": "#/definitions/ToolsListChangedDisposition"
    },
    "pending_since": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "received_at": {
      "type": "string",
      "format": "date-time"
    },
    "removed_count": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "server_id": {
      "$ref": "#/definitions/McpServerId"
    },
    "session_id": {
      "anyOf": [
        {
          "$ref": "#/definitions/TypedUlid"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "definitions": {
    "McpServerId": {
      "type": "string"
    },
    "ToolsListChangedDisposition": {
      "type": "string",
      "enum": [
        "deferred_applied",
        "pending_for_reload",
        "no_change"
      ]
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
