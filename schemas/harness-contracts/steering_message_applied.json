{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SteeringMessageAppliedEvent",
  "type": "object",
  "required": [
    "at",
    "ids",
    "kind_distribution",
    "run_id",
    "session_id"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "ids": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/TypedUlid"
      }
    },
    "kind_distribution": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "format": "uint32",
        "minimum": 0.0
      }
    },
    "merged_into_message_id": {
      "anyOf": [
        {
          "$ref": "#/definitions/TypedUlid"
        },
        {
          "type": "null"
        }
      ]
    },
    "run_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "session_id": {
      "$ref": "#/definitions/TypedUlid"
    }
  },
  "definitions": {
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
