{
  "name": "@octopus/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/app.ts"
  },
  "types": "./src/app.ts",
  "scripts": {
    "build": "vite build",
    "ui:dev": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "ui:build": "vite build",
    "tauri": "tauri",
    "dev": "pnpm tauri dev",
    "open": "pnpm build && cargo run --manifest-path src-tauri/Cargo.toml",
    "smoke:local-host": "vitest run test/bootstrap-smoke.test.ts",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@octopus/hub-client": "workspace:*",
    "@octopus/schema-ts": "workspace:*",
    "@tauri-apps/api": "^2.0.0",
    "pinia": "^3.0.3",
    "vue": "^3.5.22",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@tauri-apps/cli": "^2.10.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.1.1"
  }
}
