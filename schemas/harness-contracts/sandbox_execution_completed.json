{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SandboxExecutionCompletedEvent",
  "type": "object",
  "required": [
    "at",
    "duration_ms",
    "status",
    "tool_use_id"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "duration_ms": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "status": {
      "$ref": "#/definitions/SandboxExitStatus"
    },
    "tool_use_id": {
      "$ref": "#/definitions/TypedUlid"
    }
  },
  "definitions": {
    "SandboxExitStatus": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "timeout",
            "cancelled"
          ]
        },
        {
          "type": "object",
          "required": [
            "code"
          ],
          "properties": {
            "code": {
              "type": "integer",
              "format": "int32"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "signal"
          ],
          "properties": {
            "signal": {
              "type": "integer",
              "format": "int32"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
