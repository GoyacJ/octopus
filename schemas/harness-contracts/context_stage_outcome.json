{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ContextStageOutcome",
  "oneOf": [
    {
      "type": "string",
      "enum": [
        "no_change",
        "modified",
        "skipped_no_aux_provider"
      ]
    },
    {
      "type": "object",
      "required": [
        "forked"
      ],
      "properties": {
        "forked": {
          "type": "object",
          "required": [
            "child"
          ],
          "properties": {
            "child": {
              "$ref": "#/definitions/TypedUlid"
            }
          }
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": [
        "skipped_aux_cooldown"
      ],
      "properties": {
        "skipped_aux_cooldown": {
          "type": "object",
          "required": [
            "until_turn"
          ],
          "properties": {
            "until_turn": {
              "type": "integer",
              "format": "uint32",
              "minimum": 0.0
            }
          }
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": [
        "failed"
      ],
      "properties": {
        "failed": {
          "type": "object",
          "required": [
            "reason"
          ],
          "properties": {
            "reason": {
              "type": "string"
            }
          }
        }
      },
      "additionalProperties": false
    }
  ],
  "definitions": {
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
