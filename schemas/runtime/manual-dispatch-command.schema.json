{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/runtime/manual-dispatch-command.schema.json",
  "title": "ManualDispatchCommand",
  "type": "object",
  "description": "Minimum GA manual dispatch command for manual_event triggers only.",
  "properties": {
    "trigger_id": {
      "type": "string",
      "minLength": 1
