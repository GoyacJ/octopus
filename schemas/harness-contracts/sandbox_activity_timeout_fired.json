{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SandboxActivityTimeoutFiredEvent",
  "type": "object",
  "required": [
    "at",
    "backend_id",
    "configured_timeout",
    "kill_scope",
    "run_id",
    "session_id"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "backend_id": {
      "type": "string"
    },
    "configured_timeout": {
      "$ref": "#/definitions/Duration"
    },
    "kill_scope": {
      "$ref": "#/definitions/KillScope"
    },
    "run_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "session_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "tool_use_id": {
      "anyOf": [
        {
          "$ref": "#/definitions/TypedUlid"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "definitions": {
    "Duration": {
      "type": "object",
      "required": [
        "nanos",
        "secs"
      ],
      "properties": {
        "nanos": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "secs": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "KillScope": {
      "type": "string",
      "enum": [
        "process",
        "process_group",
        "session_leader"
      ]
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
