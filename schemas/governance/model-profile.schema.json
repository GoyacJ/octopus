{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/governance/model-profile.schema.json",
  "title": "ModelProfile",
  "type": "object",
  "description": "Post-GA model-center foundation shared contract for a named model profile selected by agents and system defaults.",
  "properties": {
    "id": { "type": "string" },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "scope_ref": {
      "type": "string",
      "minLength": 1
    },
    "primary_model_key": {
      "type": "string",
      "minLength": 1
    },
    "fallback_model_keys": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "required": [
    "id",
    "display_name",
    "scope_ref",
    "primary_model_key",
    "fallback_model_keys",
    "created_at",
    "updated_at"
  ],
  "additionalProperties": false
}
