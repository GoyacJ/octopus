{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ToolRegistrationShadowedEvent",
  "type": "object",
  "required": [
    "at",
    "reason",
    "tool_name"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "reason": {
      "$ref": "#/definitions/ShadowReason"
    },
    "tool_name": {
      "type": "string"
    }
  },
  "definitions": {
    "ShadowReason": {
      "type": "string",
      "enum": [
        "builtin_wins",
        "higher_trust",
        "duplicate"
      ]
    }
  }
}
