{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ToolUseRequestedEvent",
  "type": "object",
  "required": [
    "at",
    "causation_id",
    "input",
    "properties",
    "run_id",
    "tool_name",
    "tool_use_id"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "causation_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "input": true,
    "properties": {
      "$ref": "#/definitions/ToolProperties"
    },
    "run_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "tool_name": {
      "type": "string"
    },
    "tool_use_id": {
      "$ref": "#/definitions/TypedUlid"
    }
  },
  "definitions": {
    "DeferPolicy": {
      "type": "string",
      "enum": [
        "always_load",
        "auto_defer",
        "force_defer"
      ]
    },
    "Duration": {
      "type": "object",
      "required": [
        "nanos",
        "secs"
      ],
      "properties": {
        "nanos": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "secs": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "LongRunningPolicy": {
      "type": "object",
      "required": [
        "hard_timeout",
        "stall_threshold"
      ],
      "properties": {
        "hard_timeout": {
          "$ref": "#/definitions/Duration"
        },
        "stall_threshold": {
          "$ref": "#/definitions/Duration"
        }
      }
    },
    "ToolProperties": {
      "type": "object",
      "required": [
        "defer_policy",
        "is_concurrency_safe",
        "is_destructive",
        "is_read_only"
      ],
      "properties": {
        "defer_policy": {
          "$ref": "#/definitions/DeferPolicy"
        },
        "is_concurrency_safe": {
          "type": "boolean"
        },
        "is_destructive": {
          "type": "boolean"
        },
        "is_read_only": {
          "type": "boolean"
        },
        "long_running": {
          "anyOf": [
            {
              "$ref": "#/definitions/LongRunningPolicy"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
