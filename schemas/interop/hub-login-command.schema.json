{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/interop/hub-login-command.schema.json",
  "title": "HubLoginCommand",
  "description": "Minimum remote-hub login command used to open a workspace-scoped remote session.",
  "type": "object",
  "properties": {
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "password": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": ["workspace_id", "email", "password"],
  "additionalProperties": false
}
