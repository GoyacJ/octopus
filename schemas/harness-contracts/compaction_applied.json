{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CompactionAppliedEvent",
  "type": "object",
  "required": [
    "after_tokens",
    "at",
    "before_tokens",
    "outcome",
    "session_id",
    "strategy",
    "summary_ref",
    "trigger"
  ],
  "properties": {
    "after_tokens": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "before_tokens": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "child_session_id": {
      "anyOf": [
        {
          "$ref": "#/definitions/TypedUlid"
        },
        {
          "type": "null"
        }
      ]
    },
    "handoff": {
      "anyOf": [
        {
          "$ref": "#/definitions/CompactionHandoff"
        },
        {
          "type": "null"
        }
      ]
    },
    "outcome": {
      "$ref": "#/definitions/CompactOutcome"
    },
    "session_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "strategy": {
      "type": "string"
    },
    "summary_ref": {
      "$ref": "#/definitions/BlobRef"
    },
    "trigger": {
      "$ref": "#/definitions/CompactTrigger"
    }
  },
  "definitions": {
    "BlobRef": {
      "type": "object",
      "required": [
        "content_hash",
        "id",
        "size"
      ],
      "properties": {
        "content_hash": {
          "type": "array",
          "items": {
            "type": "integer",
            "format": "uint8",
            "minimum": 0.0
          },
          "maxItems": 32,
          "minItems": 32
        },
        "content_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "$ref": "#/definitions/TypedUlid"
        },
        "size": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "CompactOutcome": {
      "type": "string",
      "enum": [
        "applied",
        "degraded",
        "reactive_failed"
      ]
    },
    "CompactTrigger": {
      "type": "string",
      "enum": [
        "soft_budget",
        "hard_budget",
        "provider_reported",
        "user_command"
      ]
    },
    "CompactionHandoff": {
      "type": "object",
      "required": [
        "metadata",
        "summary_ref"
      ],
      "properties": {
        "metadata": true,
        "summary_ref": {
          "$ref": "#/definitions/BlobRef"
        }
      }
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
