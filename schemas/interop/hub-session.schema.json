{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/interop/hub-session.schema.json",
  "title": "HubSession",
  "description": "Minimum remote-hub authenticated session summary shared across Rust and TypeScript clients.",
  "type": "object",
  "properties": {
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "user_id": {
      "type": "string",
      "minLength": 1
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "actor_ref": {
      "type": "string",
      "minLength": 1
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "session_id",
    "user_id",
    "email",
    "workspace_id",
    "actor_ref",
    "issued_at",
    "expires_at"
  ],
  "additionalProperties": false
}
