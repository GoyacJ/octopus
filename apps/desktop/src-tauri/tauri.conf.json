{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Octopus Desktop",
  "version": "0.1.0",
  "identifier": "com.octopus.desktop",
  "build": {
    "beforeDevCommand": "pnpm run ui:dev",
    "beforeBuildCommand": "pnpm run ui:build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Octopus Desktop",
        "width": 1440,
        "height": 960
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": []
  }
}
