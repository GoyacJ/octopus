{
  "name": "@octopus/api-client",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "lint": "eslint .",
    "generate": "openapi-typescript ../../proto/openapi/control-plane.v1.yaml -o src/generated/control-plane.ts",
    "check:generated": "pnpm run generate && git diff --exit-code -- src/generated/control-plane.ts",
    "lint:openapi": "spectral lint --ruleset ../../.spectral.js ../../proto/openapi/control-plane.v1.yaml",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "build": "tsc -p tsconfig.build.json"
  },
  "devDependencies": {
    "@octopus/tsconfig": "workspace:*",
    "@stoplight/spectral-cli": "^6.15.0",
    "openapi-typescript": "^7.10.1"
  }
}
