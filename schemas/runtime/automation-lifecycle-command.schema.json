{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/runtime/automation-lifecycle-command.schema.json",
  "title": "AutomationLifecycleCommand",
  "type": "object",
  "description": "Minimum GA automation lifecycle command limited to activate, pause, and archive transitions.",
  "properties": {
    "automation_id": {
      "type": "string",
      "minLength": 1
    },
    "action": {
      "type": "string",
      "enum": ["activate", "pause", "archive"]
    }
  },
  "required": ["automation_id", "action"],
  "additionalProperties": false
}
