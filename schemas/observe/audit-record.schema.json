{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/observe/audit-record.schema.json",
  "title": "AuditRecord",
  "type": "object",
  "description": "Slice 1 shared contract for audit records emitted during task intake and run orchestration.",
  "properties": {
    "id": { "type": "string" },
    "workspace_id": { "type": "string" },
    "project_id": { "type": "string" },
    "run_id": { "type": "string" },
    "task_id": { "type": "string" },
    "event_type": {
      "type": "string",
      "enum": [
        "task_created",
        "automation_created",
        "trigger_delivery_created",
        "trigger_delivery_retry_requested",
        "trigger_delivery_succeeded",
        "trigger_delivery_failed",
        "run_created",
        "run_started",
        "run_completed",
        "run_failed",
        "run_retry_requested",
        "run_terminated",
        "artifact_created",
        "approval_requested",
        "approval_approved",
        "approval_rejected",
        "approval_expired",
        "approval_cancelled",
        "run_blocked",
        "policy_denied",
        "knowledge_candidate_created",
        "knowledge_capture_gated",
        "knowledge_capture_failed",
        "knowledge_capture_retried",
        "knowledge_asset_promoted",
        "knowledge_recalled"
      ]
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "required": [
    "id",
    "workspace_id",
    "project_id",
    "run_id",
    "task_id",
    "event_type",
    "message",
    "created_at"
  ],
  "additionalProperties": false
}
