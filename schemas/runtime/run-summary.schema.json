{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/runtime/run-summary.schema.json",
  "title": "RunSummary",
  "type": "object",
  "description": "GA minimum-surface shared summary contract for Run list rows, state blocks, and stream updates.",
  "properties": {
    "id": { "type": "string" },
    "task_id": { "type": "string" },
    "workspace_id": { "type": "string" },
    "project_id": { "type": "string" },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "run_type": {
      "type": "string",
      "enum": ["task", "automation"]
    },
    "status": {
      "$ref": "https://octopus.local/schemas/runtime/run-status.schema.json"
    },
    "approval_request_id": {
      "type": ["string", "null"]
    },
    "attempt_count": {
      "type": "integer",
      "minimum": 0
    },
    "max_attempts": {
      "type": "integer",
      "minimum": 1
    },
    "last_error": {
      "type": ["string", "null"]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "started_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "completed_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "terminated_at": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  },
  "required": [
    "id",
    "task_id",
    "workspace_id",
    "project_id",
    "title",
    "run_type",
    "status",
    "approval_request_id",
    "attempt_count",
    "max_attempts",
    "last_error",
    "created_at",
    "updated_at",
    "started_at",
    "completed_at",
    "terminated_at"
  ],
  "additionalProperties": false
}
