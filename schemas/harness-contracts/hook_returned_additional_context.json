{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HookContextPatchEvent",
  "type": "object",
  "required": [
    "at",
    "byte_size",
    "causation_id",
    "handler_id",
    "hook_event_kind"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "byte_size": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "causation_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "context_blob": {
      "anyOf": [
        {
          "$ref": "#/definitions/BlobRef"
        },
        {
          "type": "null"
        }
      ]
    },
    "handler_id": {
      "type": "string"
    },
    "hook_event_kind": {
      "$ref": "#/definitions/HookEventKind"
    }
  },
  "definitions": {
    "BlobRef": {
      "type": "object",
      "required": [
        "content_hash",
        "id",
        "size"
      ],
      "properties": {
        "content_hash": {
          "type": "array",
          "items": {
            "type": "integer",
            "format": "uint8",
            "minimum": 0.0
          },
          "maxItems": 32,
          "minItems": 32
        },
        "content_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "$ref": "#/definitions/TypedUlid"
        },
        "size": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "HookEventKind": {
      "type": "string",
      "enum": [
        "pre_tool_use",
        "post_tool_use",
        "transform_tool_result",
        "pre_model",
        "post_model",
        "session_start",
        "session_end"
      ]
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
