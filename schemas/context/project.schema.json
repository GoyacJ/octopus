{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/context/project.schema.json",
  "title": "Project",
  "type": "object",
  "description": "Slice 1 shared contract for Project as a Workspace-scoped business context boundary for runs and artifacts.",
  "properties": {
    "id": { "type": "string" },
    "workspace_id": { "type": "string" },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,62}$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "required": ["id", "workspace_id", "slug", "display_name", "created_at", "updated_at"],
  "additionalProperties": false
}
