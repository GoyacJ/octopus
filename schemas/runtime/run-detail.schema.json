{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/runtime/run-detail.schema.json",
  "title": "RunDetail",
  "type": "object",
  "description": "GA minimum-surface shared detail contract for the authoritative Run page.",
  "properties": {
    "run": {
      "$ref": "https://octopus.local/schemas/runtime/run.schema.json"
    },
    "task": {
      "$ref": "https://octopus.local/schemas/runtime/task.schema.json"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "https://octopus.local/schemas/observe/artifact.schema.json"
      }
    },
    "audits": {
      "type": "array",
      "items": {
        "$ref": "https://octopus.local/schemas/observe/audit-record.schema.json"
      }
    },
    "traces": {
      "type": "array",
      "items": {
        "$ref": "https://octopus.local/schemas/observe/trace-record.schema.json"
      }
    },
    "approvals": {
      "type": "array",
      "items": {
        "$ref": "https://octopus.local/schemas/governance/approval-request.schema.json"
      }
    },
    "inbox_items": {
      "type": "array",
      "items": {
        "$ref": "https://octopus.local/schemas/observe/inbox-item.schema.json"
      }
    },
    "notifications": {
      "type": "array",
      "items": {
        "$ref": "https://octopus.local/schemas/observe/notification.schema.json"
      }
    },
    "policy_decisions": {
      "type": "array",
      "items": {
        "$ref": "https://octopus.local/schemas/observe/policy-decision-log.schema.json"
      }
    },
    "knowledge_candidates": {
      "type": "array",
      "items": {
        "$ref": "https://octopus.local/schemas/observe/knowledge-candidate.schema.json"
      }
    },
    "knowledge_assets": {
      "type": "array",
      "items": {
        "$ref": "https://octopus.local/schemas/observe/knowledge-asset.schema.json"
      }
    },
    "knowledge_lineage": {
      "type": "array",
      "items": {
        "$ref": "https://octopus.local/schemas/observe/knowledge-lineage-record.schema.json"
      }
    }
  },
  "required": [
    "run",
    "task",
    "artifacts",
    "audits",
    "traces",
    "approvals",
    "inbox_items",
    "notifications",
    "policy_decisions",
    "knowledge_candidates",
    "knowledge_assets",
    "knowledge_lineage"
  ],
  "additionalProperties": false
}
