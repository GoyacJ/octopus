{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/governance/model-catalog-item.schema.json",
  "title": "ModelCatalogItem",
  "type": "object",
  "description": "Post-GA model-center foundation shared contract for a cataloged model entry governed by the Hub.",
  "properties": {
    "id": { "type": "string" },
    "provider_id": { "type": "string" },
    "model_key": {
      "type": "string",
      "minLength": 1
    },
    "provider_model_id": {
      "type": "string",
      "minLength": 1
    },
    "release_channel": {
      "type": "string",
      "enum": ["ga", "preview", "experimental", "deprecated"]
    },
    "modality_tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "feature_tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "context_window": {
      "type": "integer",
      "minimum": 1
    },
    "max_output_tokens": {
      "type": ["integer", "null"],
      "minimum": 1
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "required": [
    "id",
    "provider_id",
    "model_key",
    "provider_model_id",
    "release_channel",
    "modality_tags",
    "feature_tags",
    "context_window",
    "max_output_tokens",
    "created_at",
    "updated_at"
  ],
  "additionalProperties": false
}
