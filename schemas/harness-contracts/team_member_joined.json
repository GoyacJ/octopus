{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TeamMemberJoinedEvent",
  "type": "object",
  "required": [
    "agent_id",
    "at",
    "spec_hash",
    "spec_snapshot_id",
    "team_id"
  ],
  "properties": {
    "agent_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "spec_hash": {
      "type": "array",
      "items": {
        "type": "integer",
        "format": "uint8",
        "minimum": 0.0
      },
      "maxItems": 32,
      "minItems": 32
    },
    "spec_snapshot_id": {
      "$ref": "#/definitions/BlobRef"
    },
    "team_id": {
      "$ref": "#/definitions/TypedUlid"
    }
  },
  "definitions": {
    "BlobRef": {
      "type": "object",
      "required": [
        "content_hash",
        "id",
        "size"
      ],
      "properties": {
        "content_hash": {
          "type": "array",
          "items": {
            "type": "integer",
            "format": "uint8",
            "minimum": 0.0
          },
          "maxItems": 32,
          "minItems": 32
        },
        "content_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "$ref": "#/definitions/TypedUlid"
        },
        "size": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
