{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ContextBudgetExceededEvent",
  "type": "object",
  "required": [
    "at",
    "budget_kind",
    "max",
    "requested",
    "session_id",
    "source"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "budget_kind": {
      "$ref": "#/definitions/BudgetKind"
    },
    "max": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "requested": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "session_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "source": {
      "$ref": "#/definitions/BudgetExceedanceSource"
    }
  },
  "definitions": {
    "BudgetExceedanceSource": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "local_estimate"
          ]
        },
        {
          "type": "object",
          "required": [
            "provider_report"
          ],
          "properties": {
            "provider_report": {
              "type": "object",
              "required": [
                "reported_tokens"
              ],
              "properties": {
                "reported_tokens": {
                  "type": "integer",
                  "format": "uint64",
                  "minimum": 0.0
                }
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "BudgetKind": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "soft_budget",
            "hard_budget",
            "per_turn_tokens",
            "per_session_tokens"
          ]
        },
        {
          "type": "object",
          "required": [
            "per_tool_max_chars"
          ],
          "properties": {
            "per_tool_max_chars": {
              "type": "object",
              "required": [
                "tool_name"
              ],
              "properties": {
                "tool_name": {
                  "type": "string"
                }
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
