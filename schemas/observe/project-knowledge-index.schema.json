{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/observe/project-knowledge-index.schema.json",
  "title": "ProjectKnowledgeIndex",
  "type": "object",
  "description": "Slice 15 shared contract for the project-scoped Shared Knowledge read index.",
  "properties": {
    "knowledge_space": {
      "$ref": "https://octopus.local/schemas/context/knowledge-space.schema.json"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "https://octopus.local/schemas/observe/knowledge-summary.schema.json"
      }
    }
  },
  "required": ["knowledge_space", "entries"],
  "additionalProperties": false
}
