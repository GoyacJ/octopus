{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MemoryRecalledEvent",
  "type": "object",
  "required": [
    "at",
    "deadline_used_ms",
    "injected_chars",
    "kept_count",
    "kinds_returned",
    "min_similarity",
    "provider_id",
    "query_text_hash",
    "returned_count",
    "run_id",
    "session_id",
    "turn"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "deadline_used_ms": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "injected_chars": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "kept_count": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "kinds_returned": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/MemoryKind"
      }
    },
    "min_similarity": {
      "type": "number",
      "format": "float"
    },
    "provider_id": {
      "type": "string"
    },
    "query_text_hash": {
      "$ref": "#/definitions/ContentHash"
    },
    "returned_count": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "run_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "session_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "turn": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    }
  },
  "definitions": {
    "ContentHash": {
      "type": "array",
      "items": {
        "type": "integer",
        "format": "uint8",
        "minimum": 0.0
      },
      "maxItems": 32,
      "minItems": 32
    },
    "MemoryKind": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "user_preference",
            "feedback",
            "project_fact",
            "reference",
            "agent_self_note"
          ]
        },
        {
          "type": "object",
          "required": [
            "custom"
          ],
          "properties": {
            "custom": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
