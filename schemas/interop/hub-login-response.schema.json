{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/interop/hub-login-response.schema.json",
  "title": "HubLoginResponse",
  "description": "Minimum remote-hub login response carrying an access token plus session summary.",
  "type": "object",
  "properties": {
    "access_token": {
      "type": "string",
      "minLength": 1
    },
    "session": {
      "$ref": "https://octopus.local/schemas/interop/hub-session.schema.json"
    }
  },
  "required": ["access_token", "session"],
  "additionalProperties": false
}
