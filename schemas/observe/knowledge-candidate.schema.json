{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/observe/knowledge-candidate.schema.json",
  "title": "KnowledgeCandidate",
  "type": "object",
  "description": "Slice 4 shared contract for candidate knowledge captured from successful execution artifacts before promotion into shared knowledge.",
  "properties": {
    "id": { "type": "string" },
    "knowledge_space_id": { "type": "string" },
    "source_run_id": { "type": "string" },
    "source_task_id": { "type": "string" },
    "source_artifact_id": { "type": "string" },
    "capability_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "$ref": "https://octopus.local/schemas/observe/knowledge-candidate-status.schema.json"
    },
    "content": {
      "type": "string",
      "minLength": 1
    },
    "dedupe_key": {
      "type": "string",
      "minLength": 1
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "required": [
    "id",
    "knowledge_space_id",
    "source_run_id",
    "source_task_id",
    "source_artifact_id",
    "capability_id",
    "status",
    "content",
    "dedupe_key",
    "created_at",
    "updated_at"
  ],
  "additionalProperties": false
}
