{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RunEndedEvent",
  "type": "object",
  "required": [
    "ended_at",
    "reason",
    "run_id"
  ],
  "properties": {
    "ended_at": {
      "type": "string",
      "format": "date-time"
    },
    "reason": {
      "$ref": "#/definitions/EndReason"
    },
    "run_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "usage": {
      "anyOf": [
        {
          "$ref": "#/definitions/UsageSnapshot"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "definitions": {
    "CancelInitiator": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "user",
            "parent"
          ]
        },
        {
          "type": "object",
          "required": [
            "system"
          ],
          "properties": {
            "system": {
              "type": "object",
              "required": [
                "reason"
              ],
              "properties": {
                "reason": {
                  "type": "string"
                }
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "EndReason": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "completed",
            "max_iterations_reached",
            "token_budget_exhausted",
            "interrupted",
            "compacted"
          ]
        },
        {
          "type": "object",
          "required": [
            "cancelled"
          ],
          "properties": {
            "cancelled": {
              "type": "object",
              "required": [
                "initiator"
              ],
              "properties": {
                "initiator": {
                  "$ref": "#/definitions/CancelInitiator"
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "error"
          ],
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    },
    "UsageSnapshot": {
      "type": "object",
      "required": [
        "cache_read_tokens",
        "cache_write_tokens",
        "cost_micros",
        "input_tokens",
        "output_tokens"
      ],
      "properties": {
        "cache_read_tokens": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "cache_write_tokens": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "cost_micros": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "input_tokens": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "output_tokens": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    }
  }
}
