{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SandboxSnapshotCreatedEvent",
  "type": "object",
  "required": [
    "at",
    "backend_id",
    "content_hash",
    "kind",
    "session_id",
    "size_bytes"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "backend_id": {
      "type": "string"
    },
    "content_hash": {
      "type": "array",
      "items": {
        "type": "integer",
        "format": "uint8",
        "minimum": 0.0
      },
      "maxItems": 32,
      "minItems": 32
    },
    "kind": {
      "$ref": "#/definitions/SessionSnapshotKind"
    },
    "session_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "size_bytes": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    }
  },
  "definitions": {
    "SessionSnapshotKind": {
      "type": "string",
      "enum": [
        "filesystem_image",
        "shell_state",
        "container_image"
      ]
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
