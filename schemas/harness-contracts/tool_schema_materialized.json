{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ToolSchemaMaterializedEvent",
  "type": "object",
  "required": [
    "at",
    "schema_hash",
    "tool_name"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "schema_hash": {
      "type": "array",
      "items": {
        "type": "integer",
        "format": "uint8",
        "minimum": 0.0
      },
      "maxItems": 32,
      "minItems": 32
    },
    "tool_name": {
      "type": "string"
    }
  }
}
