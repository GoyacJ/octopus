{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ElicitationOutcome",
  "oneOf": [
    {
      "type": "string",
      "enum": [
        "user_declined",
        "timeout",
        "no_handler_registered"
      ]
    },
    {
      "type": "object",
      "required": [
        "provided"
      ],
      "properties": {
        "provided": {
          "type": "object",
          "required": [
            "value_hash"
          ],
          "properties": {
            "value_hash": {
              "type": "array",
              "items": {
                "type": "integer",
                "format": "uint8",
                "minimum": 0.0
              },
              "maxItems": 32,
              "minItems": 32
            }
          }
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": [
        "invalid"
      ],
      "properties": {
        "invalid": {
          "type": "object",
          "required": [
            "reason"
          ],
          "properties": {
            "reason": {
              "type": "string"
            }
          }
        }
      },
      "additionalProperties": false
    }
  ]
}
