{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentMessageSentEvent",
  "type": "object",
  "required": [
    "at",
    "from",
    "message_id",
    "payload",
    "team_id",
    "to"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "from": {
      "$ref": "#/definitions/TypedUlid"
    },
    "message_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "payload": {
      "$ref": "#/definitions/MessagePayload"
    },
    "team_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "to": {
      "$ref": "#/definitions/Recipient"
    }
  },
  "definitions": {
    "MessagePayload": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "text"
          ],
          "properties": {
            "text": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "structured"
          ],
          "properties": {
            "structured": true
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "request"
          ],
          "properties": {
            "request": {
              "type": "object",
              "required": [
                "reply_to"
              ],
              "properties": {
                "reply_to": {
                  "$ref": "#/definitions/TypedUlid"
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "response"
          ],
          "properties": {
            "response": {
              "type": "object",
              "required": [
                "body",
                "in_reply_to"
              ],
              "properties": {
                "body": true,
                "in_reply_to": {
                  "$ref": "#/definitions/TypedUlid"
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "handoff"
          ],
          "properties": {
            "handoff": {
              "type": "object",
              "required": [
                "summary",
                "to"
              ],
              "properties": {
                "summary": {
                  "type": "string"
                },
                "to": {
                  "$ref": "#/definitions/TypedUlid"
                }
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "Recipient": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "broadcast",
            "coordinator"
          ]
        },
        {
          "type": "object",
          "required": [
            "agent"
          ],
          "properties": {
            "agent": {
              "$ref": "#/definitions/TypedUlid"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "role"
          ],
          "properties": {
            "role": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
