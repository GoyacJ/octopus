{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "sourceMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "noEmit": true,
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@octopus/assets/pets": ["../../packages/assets/pets/index.ts"],
      "@octopus/assets/pets/*": ["../../packages/assets/pets/*"],
      "@octopus/schema": ["../../packages/schema/src/index.ts"],
      "@octopus/schema/*": ["../../packages/schema/src/*"],
      "@octopus/ui": ["../../packages/ui/src/index.ts"],
      "@octopus/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.tsx", "src/**/*.vue"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
