{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/runtime/create-automation-command.schema.json",
  "title": "CreateAutomationCommand",
  "type": "object",
  "description": "Minimum GA automation create command covering existing automation execution inputs plus the four trigger creation variants.",
  "properties": {
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "instruction": {
      "type": "string",
      "minLength": 1
    },
    "action": {
      "$ref": "https://octopus.local/schemas/runtime/automation.schema.json#/properties/action"
    },
    "capability_id": {
      "type": "string",
      "minLength": 1
    },
    "estimated_cost": {
      "type": "integer",
      "minimum": 0
    },
    "trigger": {
      "$ref": "https://octopus.local/schemas/runtime/create-trigger-input.schema.json"
    }
  },
  "required": [
    "workspace_id",
    "project_id",
    "title",
    "instruction",
    "action",
    "capability_id",
    "estimated_cost",
    "trigger"
  ],
  "additionalProperties": false
}
