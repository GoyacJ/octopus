{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CompactionAppliedEvent",
  "type": "object",
  "required": [
    "after_tokens",
    "at",
    "before_tokens",
    "outcome",
    "session_id",
    "strategy",
    "summary_ref",
    "trigger"
  ],
  "properties": {
    "after_tokens": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "before_tokens": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "child_session_id": {
      "anyOf": [
        {
          "$ref": "#/definitions/TypedUlid"
        },
        {
          "type": "null"
        }
      ]
    },
    "handoff": {
      "anyOf": [
        {
          "$ref": "#/definitions/CompactionHandoff"
        },
        {
          "type": "null"
        }
      ]
    },
    "outcome": {
      "$ref": "#/definitions/CompactOutcome"
    },
    "session_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "strategy": {
      "type": "string"
    },
    "summary_ref": {
      "$ref": "#/definitions/BlobRef"
    },
    "trigger": {
      "$ref": "#/definitions/CompactTrigger"
    }
  },
  "definitions": {
    "BlobRef": {
      "type": "object",
      "required": [
        "content_hash",
        "id",
        "size"
      ],
      "properties": {
        "content_hash": {
          "type": "array",
          "items": {
            "type": "integer",
            "format": "uint8",
            "minimum": 0.0
          },
          "maxItems": 32,
          "minItems": 32
        },
        "content_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "$ref": "#/definitions/TypedUlid"
        },
        "size": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "CompactOutcome": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "succeeded",
            "degraded_no_aux_provider",
            "reactive_attempt_failed"
          ]
        },
        {
          "type": "object",
          "required": [
            "degraded_aux_failure"
          ],
          "properties": {
            "degraded_aux_failure": {
              "type": "object",
              "required": [
                "failure_count"
              ],
              "properties": {
                "failure_count": {
                  "type": "integer",
                  "format": "uint32",
                  "minimum": 0.0
                }
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "CompactTrigger": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "soft_budget",
            "hard_budget",
            "user_command"
          ]
        },
        {
          "type": "object",
          "required": [
            "provider_report"
          ],
          "properties": {
            "provider_report": {
              "type": "object",
              "required": [
                "reported_tokens"
              ],
              "properties": {
                "reported_tokens": {
                  "type": "integer",
                  "format": "uint64",
                  "minimum": 0.0
                }
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "CompactionHandoff": {
      "type": "object",
      "required": [
        "active_task_ref",
        "outstanding_permissions",
        "pending_tool_uses",
        "remaining_budget"
      ],
      "properties": {
        "active_task_ref": {
          "$ref": "#/definitions/BlobRef"
        },
        "outstanding_permissions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/TypedUlid"
          }
        },
        "pending_tool_uses": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/TypedUlid"
          }
        },
        "remaining_budget": {
          "$ref": "#/definitions/RemainingBudget"
        }
      }
    },
    "RemainingBudget": {
      "type": "object",
      "required": [
        "iterations_remaining",
        "tokens_remaining_in_session"
      ],
      "properties": {
        "iterations_remaining": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "tokens_remaining_in_session": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "wall_clock_deadline": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
