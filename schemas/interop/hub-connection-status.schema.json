{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/interop/hub-connection-status.schema.json",
  "title": "HubConnectionStatus",
  "type": "object",
  "description": "GA minimum-surface shared contract for local or remote Hub connection status shown in the workspace shell.",
  "$defs": {
    "server_summary": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "capability_id": { "type": "string" },
        "namespace": {
          "type": "string",
          "minLength": 1
        },
        "platform": {
          "type": "string",
          "minLength": 1
        },
        "trust_level": {
          "type": "string",
          "enum": ["trusted", "external_untrusted"]
        },
        "health_status": {
          "type": "string",
          "enum": ["healthy", "degraded", "unreachable"]
        },
        "lease_ttl_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "last_checked_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "capability_id",
        "namespace",
        "platform",
        "trust_level",
        "health_status",
        "lease_ttl_seconds",
        "last_checked_at"
      ],
      "additionalProperties": false
    }
  },
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["local", "remote"]
    },
    "state": {
      "type": "string",
      "enum": ["connected", "degraded", "disconnected"]
    },
    "auth_state": {
      "type": "string",
      "enum": ["authenticated", "auth_required", "token_expired"]
    },
    "active_server_count": {
      "type": "integer",
      "minimum": 0
    },
    "healthy_server_count": {
      "type": "integer",
      "minimum": 0
    },
    "servers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/server_summary"
      }
    },
    "last_refreshed_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "mode",
    "state",
    "auth_state",
    "active_server_count",
    "healthy_server_count",
    "servers",
    "last_refreshed_at"
  ],
  "additionalProperties": false
}
