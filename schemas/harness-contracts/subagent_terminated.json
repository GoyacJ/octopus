{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SubagentTerminatedEvent",
  "type": "object",
  "required": [
    "at",
    "final_usage",
    "parent_session_id",
    "reason",
    "subagent_id"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "final_usage": {
      "$ref": "#/definitions/UsageSnapshot"
    },
    "parent_session_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "reason": {
      "$ref": "#/definitions/SubagentTerminationReason"
    },
    "subagent_id": {
      "$ref": "#/definitions/TypedUlid"
    }
  },
  "definitions": {
    "SubagentTerminationReason": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "natural_completion",
            "parent_cancelled",
            "bridge_broken"
          ]
        },
        {
          "type": "object",
          "required": [
            "admin_interrupted"
          ],
          "properties": {
            "admin_interrupted": {
              "type": "object",
              "required": [
                "admin_id"
              ],
              "properties": {
                "admin_id": {
                  "type": "string"
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "stalled"
          ],
          "properties": {
            "stalled": {
              "type": "object",
              "required": [
                "silent_for_ms"
              ],
              "properties": {
                "silent_for_ms": {
                  "type": "integer",
                  "format": "uint64",
                  "minimum": 0.0
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "failed"
          ],
          "properties": {
            "failed": {
              "type": "object",
              "required": [
                "detail"
              ],
              "properties": {
                "detail": {
                  "type": "string"
                }
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    },
    "UsageSnapshot": {
      "type": "object",
      "required": [
        "cache_read_tokens",
        "cache_write_tokens",
        "cost_micros",
        "input_tokens",
        "output_tokens"
      ],
      "properties": {
        "cache_read_tokens": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "cache_write_tokens": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "cost_micros": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "input_tokens": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "output_tokens": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    }
  }
}
