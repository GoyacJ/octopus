{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/runtime/run.schema.json",
  "title": "Run",
  "type": "object",
  "description": "Slice 3 shared contract for Run as the authority execution shell for manual and automation execution.",
  "properties": {
    "id": { "type": "string" },
    "task_id": { "type": "string" },
    "workspace_id": { "type": "string" },
    "project_id": { "type": "string" },
    "automation_id": {
      "type": ["string", "null"]
    },
    "trigger_delivery_id": {
      "type": ["string", "null"]
    },
    "run_type": {
      "type": "string",
      "enum": ["task", "automation"]
    },
    "status": { "$ref": "https://octopus.local/schemas/runtime/run-status.schema.json" },
    "approval_request_id": {
      "type": ["string", "null"]
    },
    "idempotency_key": { "type": "string" },
    "attempt_count": {
      "type": "integer",
      "minimum": 0
    },
    "max_attempts": {
      "type": "integer",
      "minimum": 1
    },
    "checkpoint_seq": {
      "type": "integer",
      "minimum": 0
    },
    "resume_token": {
      "type": ["string", "null"]
    },
    "last_error": {
      "type": ["string", "null"]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "started_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "completed_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "terminated_at": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  },
  "required": [
    "id",
    "task_id",
    "workspace_id",
    "project_id",
    "automation_id",
    "trigger_delivery_id",
    "run_type",
    "status",
    "approval_request_id",
    "idempotency_key",
    "attempt_count",
    "max_attempts",
    "checkpoint_seq",
    "created_at",
    "updated_at"
  ],
  "additionalProperties": false
}
