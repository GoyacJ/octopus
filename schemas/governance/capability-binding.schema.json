{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/governance/capability-binding.schema.json",
  "title": "CapabilityBinding",
  "type": "object",
  "description": "Slice 2 shared contract for binding capabilities to the current Workspace / Project scope.",
  "properties": {
    "id": { "type": "string" },
    "capability_id": { "type": "string" },
    "workspace_id": { "type": "string" },
    "project_id": { "type": "string" },
    "scope_ref": { "type": "string" },
    "binding_status": {
      "type": "string",
      "enum": ["active", "disabled"]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "required": [
    "id",
    "capability_id",
    "workspace_id",
    "project_id",
    "scope_ref",
    "binding_status",
    "created_at",
    "updated_at"
  ],
  "additionalProperties": false
}
