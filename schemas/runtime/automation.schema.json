{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/runtime/automation.schema.json",
  "title": "Automation",
  "type": "object",
  "description": "Slice 3 shared contract for reusable Automation definitions that own a default manual-event trigger and project deliveries into derived tasks.",
  "$defs": {
    "emit_text_action": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "emit_text"
        },
        "content": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["kind", "content"],
      "additionalProperties": false
    },
    "fail_once_then_emit_text_action": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "fail_once_then_emit_text"
        },
        "failure_message": {
          "type": "string",
          "minLength": 1
        },
        "content": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["kind", "failure_message", "content"],
      "additionalProperties": false
    },
    "always_fail_action": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "always_fail"
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["kind", "message"],
      "additionalProperties": false
    },
    "connector_call_action": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "connector_call"
        },
        "tool_name": {
          "type": "string",
          "minLength": 1
        },
        "arguments": {
          "type": "object"
        }
      },
      "required": ["kind", "tool_name", "arguments"],
      "additionalProperties": false
    }
  },
  "properties": {
    "id": { "type": "string" },
    "workspace_id": { "type": "string" },
    "project_id": { "type": "string" },
    "trigger_id": { "type": "string" },
    "status": {
      "$ref": "https://octopus.local/schemas/runtime/automation-status.schema.json"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "instruction": {
      "type": "string",
      "minLength": 1
    },
    "action": {
      "oneOf": [
        { "$ref": "#/$defs/emit_text_action" },
        { "$ref": "#/$defs/connector_call_action" },
        { "$ref": "#/$defs/fail_once_then_emit_text_action" },
        { "$ref": "#/$defs/always_fail_action" }
      ]
    },
    "capability_id": {
      "type": "string",
      "minLength": 1
    },
    "estimated_cost": {
      "type": "integer",
      "minimum": 0
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "required": [
    "id",
    "workspace_id",
    "project_id",
    "trigger_id",
    "status",
    "title",
    "instruction",
    "action",
    "capability_id",
    "estimated_cost",
    "created_at",
    "updated_at"
  ],
  "additionalProperties": false
}
