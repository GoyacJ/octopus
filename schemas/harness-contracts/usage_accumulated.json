{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UsageAccumulatedEvent",
  "type": "object",
  "required": [
    "at",
    "delta",
    "session_id"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "delta": {
      "$ref": "#/definitions/UsageSnapshot"
    },
    "model_ref": {
      "anyOf": [
        {
          "$ref": "#/definitions/ModelRef"
        },
        {
          "type": "null"
        }
      ]
    },
    "pricing_snapshot_id": {
      "anyOf": [
        {
          "$ref": "#/definitions/PricingSnapshotId"
        },
        {
          "type": "null"
        }
      ]
    },
    "run_id": {
      "anyOf": [
        {
          "$ref": "#/definitions/TypedUlid"
        },
        {
          "type": "null"
        }
      ]
    },
    "session_id": {
      "$ref": "#/definitions/TypedUlid"
    }
  },
  "definitions": {
    "ModelRef": {
      "type": "object",
      "required": [
        "model_id",
        "provider_id"
      ],
      "properties": {
        "model_id": {
          "type": "string"
        },
        "provider_id": {
          "type": "string"
        }
      }
    },
    "PricingSnapshotId": {
      "type": "object",
      "required": [
        "pricing_id",
        "version"
      ],
      "properties": {
        "pricing_id": {
          "type": "string"
        },
        "version": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      }
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    },
    "UsageSnapshot": {
      "type": "object",
      "required": [
        "cache_read_tokens",
        "cache_write_tokens",
        "cost_micros",
        "input_tokens",
        "output_tokens"
      ],
      "properties": {
        "cache_read_tokens": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "cache_write_tokens": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "cost_micros": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "input_tokens": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "output_tokens": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    }
  }
}
