{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BlobRef",
  "type": "object",
  "required": [
    "content_hash",
    "id",
    "size"
  ],
  "properties": {
    "content_hash": {
      "type": "array",
      "items": {
        "type": "integer",
        "format": "uint8",
        "minimum": 0.0
      },
      "maxItems": 32,
      "minItems": 32
    },
    "content_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "size": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    }
  },
  "definitions": {
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
