{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "McpToolInjectedEvent",
  "type": "object",
  "required": [
    "at",
    "defer_policy",
    "filtered_out",
    "server_id",
    "session_id",
    "tool_name",
    "upstream_name"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "defer_policy": {
      "$ref": "#/definitions/DeferPolicy"
    },
    "filter_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "filtered_out": {
      "type": "boolean"
    },
    "server_id": {
      "$ref": "#/definitions/McpServerId"
    },
    "session_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "tool_name": {
      "type": "string"
    },
    "upstream_name": {
      "type": "string"
    }
  },
  "definitions": {
    "DeferPolicy": {
      "type": "string",
      "enum": [
        "always_load",
        "auto_defer",
        "force_defer"
      ]
    },
    "McpServerId": {
      "type": "string"
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
