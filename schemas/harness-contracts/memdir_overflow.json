{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MemdirOverflowEvent",
  "type": "object",
  "required": [
    "at",
    "current_chars",
    "file",
    "session_id",
    "strategy_applied",
    "tenant_id",
    "threshold"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "current_chars": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "file": {
      "$ref": "#/definitions/MemdirFileTag"
    },
    "session_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "strategy_applied": {
      "$ref": "#/definitions/OverflowStrategy"
    },
    "tenant_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "threshold": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    }
  },
  "definitions": {
    "MemdirFileTag": {
      "type": "string",
      "enum": [
        "memory",
        "user",
        "dreams"
      ]
    },
    "OverflowStrategy": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "section_truncated"
          ],
          "properties": {
            "section_truncated": {
              "type": "object",
              "required": [
                "dropped_sections",
                "kept_sections"
              ],
              "properties": {
                "dropped_sections": {
                  "type": "integer",
                  "format": "uint32",
                  "minimum": 0.0
                },
                "kept_sections": {
                  "type": "integer",
                  "format": "uint32",
                  "minimum": 0.0
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "head_only"
          ],
          "properties": {
            "head_only": {
              "type": "object",
              "required": [
                "kept_chars"
              ],
              "properties": {
                "kept_chars": {
                  "type": "integer",
                  "format": "uint32",
                  "minimum": 0.0
                }
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
