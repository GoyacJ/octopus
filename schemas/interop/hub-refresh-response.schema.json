{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/interop/hub-refresh-response.schema.json",
  "title": "HubRefreshResponse",
  "description": "Remote-hub refresh-token exchange response carrying the next token pair plus session summary.",
  "type": "object",
  "properties": {
    "access_token": {
      "type": "string",
      "minLength": 1
    },
    "refresh_token": {
      "type": "string",
      "minLength": 1
    },
    "refresh_expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "session": {
      "$ref": "https://octopus.local/schemas/interop/hub-session.schema.json"
    }
  },
  "required": ["access_token", "refresh_token", "refresh_expires_at", "session"],
  "additionalProperties": false
}
