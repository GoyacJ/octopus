{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "McpSamplingRequestedEvent",
  "type": "object",
  "required": [
    "at",
    "input_tokens",
    "latency_ms",
    "outcome",
    "output_tokens",
    "prompt_cache_namespace",
    "request_id",
    "server_id",
    "session_id"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "input_tokens": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "latency_ms": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "model_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "outcome": {
      "$ref": "#/definitions/SamplingOutcome"
    },
    "output_tokens": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "prompt_cache_namespace": {
      "type": "string"
    },
    "request_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "run_id": {
      "anyOf": [
        {
          "$ref": "#/definitions/TypedUlid"
        },
        {
          "type": "null"
        }
      ]
    },
    "server_id": {
      "$ref": "#/definitions/McpServerId"
    },
    "session_id": {
      "$ref": "#/definitions/TypedUlid"
    }
  },
  "definitions": {
    "McpServerId": {
      "type": "string"
    },
    "SamplingBudgetDimension": {
      "type": "string",
      "enum": [
        "per_request_input_tokens",
        "per_request_output_tokens",
        "per_request_timeout",
        "per_request_tool_rounds",
        "per_server_session_input",
        "per_server_session_output",
        "per_session_input",
        "per_session_output"
      ]
    },
    "SamplingDenyReason": {
      "type": "string",
      "enum": [
        "policy_denied",
        "approval_denied",
        "model_not_allowed",
        "permission_mode_blocked",
        "inline_user_source_refused"
      ]
    },
    "SamplingOutcome": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "completed",
            "rate_limited",
            "cancelled"
          ]
        },
        {
          "type": "object",
          "required": [
            "denied"
          ],
          "properties": {
            "denied": {
              "type": "object",
              "required": [
                "reason"
              ],
              "properties": {
                "reason": {
                  "$ref": "#/definitions/SamplingDenyReason"
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "budget_exceeded"
          ],
          "properties": {
            "budget_exceeded": {
              "type": "object",
              "required": [
                "dimension"
              ],
              "properties": {
                "dimension": {
                  "$ref": "#/definitions/SamplingBudgetDimension"
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "upstream_error"
          ],
          "properties": {
            "upstream_error": {
              "type": "object",
              "required": [
                "code",
                "message"
              ],
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "message": {
                  "type": "string"
                }
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
