{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/runtime/trigger.schema.json",
  "title": "Trigger",
  "type": "object",
  "description": "GA foundation placeholder shared contract for trigger definitions that start or resume runs.",
  "properties": {
    "id": { "type": "string" },
    "automation_id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "required": ["id"],
  "additionalProperties": true
}
