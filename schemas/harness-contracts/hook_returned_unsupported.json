{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HookReturnedUnsupportedEvent",
  "type": "object",
  "required": [
    "at",
    "causation_id",
    "handler_id",
    "hook_event_kind",
    "returned_kind"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "causation_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "handler_id": {
      "type": "string"
    },
    "hook_event_kind": {
      "$ref": "#/definitions/HookEventKind"
    },
    "returned_kind": {
      "$ref": "#/definitions/HookOutcomeDiscriminant"
    }
  },
  "definitions": {
    "HookEventKind": {
      "type": "string",
      "enum": [
        "user_prompt_submit",
        "pre_tool_use",
        "post_tool_use",
        "post_tool_use_failure",
        "permission_request",
        "session_start",
        "setup",
        "session_end",
        "subagent_start",
        "subagent_stop",
        "notification",
        "pre_llm_call",
        "post_llm_call",
        "pre_api_request",
        "post_api_request",
        "transform_tool_result",
        "transform_terminal_output",
        "elicitation",
        "pre_tool_search",
        "post_tool_search_materialize"
      ]
    },
    "HookOutcomeDiscriminant": {
      "type": "string",
      "enum": [
        "continue",
        "block",
        "pre_tool_use",
        "rewrite_input",
        "override_permission",
        "add_context",
        "transform"
      ]
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
