{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentMessageRoutedEvent",
  "type": "object",
  "required": [
    "at",
    "message_id",
    "resolved_recipients",
    "routing_policy",
    "team_id"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "message_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "resolved_recipients": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/TypedUlid"
      }
    },
    "routing_policy": {
      "$ref": "#/definitions/RoutingPolicyKind"
    },
    "team_id": {
      "$ref": "#/definitions/TypedUlid"
    }
  },
  "definitions": {
    "RoutingPolicyKind": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "direct",
            "role",
            "broadcast",
            "coordinator"
          ]
        },
        {
          "type": "object",
          "required": [
            "custom"
          ],
          "properties": {
            "custom": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
