{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SandboxOutputSpilledEvent",
  "type": "object",
  "required": [
    "at",
    "blob_ref",
    "head_bytes",
    "original_bytes",
    "run_id",
    "session_id",
    "stream",
    "tail_bytes"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "blob_ref": {
      "$ref": "#/definitions/BlobRef"
    },
    "head_bytes": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "original_bytes": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "run_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "session_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "stream": {
      "$ref": "#/definitions/SandboxOutputStream"
    },
    "tail_bytes": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "tool_use_id": {
      "anyOf": [
        {
          "$ref": "#/definitions/TypedUlid"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "definitions": {
    "BlobRef": {
      "type": "object",
      "required": [
        "content_hash",
        "id",
        "size"
      ],
      "properties": {
        "content_hash": {
          "type": "array",
          "items": {
            "type": "integer",
            "format": "uint8",
            "minimum": 0.0
          },
          "maxItems": 32,
          "minItems": 32
        },
        "content_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "$ref": "#/definitions/TypedUlid"
        },
        "size": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "SandboxOutputStream": {
      "type": "string",
      "enum": [
        "stdout",
        "stderr",
        "combined"
      ]
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
