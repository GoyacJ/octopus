{
  "name": "octopus",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm dev:desktop",
    "dev:desktop": "pnpm prepare:desktop-backend:dev && pnpm tauri dev --config apps/desktop/src-tauri/tauri.conf.json",
    "dev:desktop:fresh": "pnpm clean:desktop-shell && pnpm dev:desktop",
    "build:desktop": "pnpm tauri build --config apps/desktop/src-tauri/tauri.conf.json",
    "prepare:desktop-backend:dev": "node scripts/prepare-desktop-backend.mjs",
    "prepare:desktop-backend:sidecar": "node scripts/prepare-desktop-sidecar.mjs",
    "clean:desktop-shell": "cargo clean -p octopus-desktop-shell",
    "prepare:agent-bundle-seed": "node scripts/prepare-agent-bundle-seed.mjs",
    "dev:web": "node scripts/dev-web.mjs",
    "dev:backend": "node scripts/run-desktop-backend.mjs",
    "build": "pnpm -C apps/desktop build:ui",
    "check:frontend": "pnpm check:frontend-governance && pnpm -C apps/desktop typecheck && pnpm -C apps/desktop test",
    "check:rust": "pnpm prepare:desktop-backend:sidecar && cargo fmt --all --check && cargo clippy --workspace --all-targets -- -D warnings && cargo test --workspace --locked",
    "check:all": "pnpm check:frontend && pnpm check:rust && pnpm schema:check && pnpm version:check",
    "check:frontend-governance": "node scripts/check-frontend-governance.mjs",
    "schema:generate": "node scripts/generate-schema.mjs",
    "schema:check": "node scripts/check-schema-governance.mjs",
    "version:sync": "node scripts/sync-version.mjs",
    "version:check": "node scripts/check-version-governance.mjs",
    "release:notes": "node scripts/generate-release-notes.mjs",
    "release:collect-artifacts": "node scripts/collect-release-artifacts.mjs",
    "release:collect-metadata": "node scripts/collect-release-metadata.mjs",
    "release:verify-artifacts": "node scripts/verify-release-artifacts.mjs",
    "test": "pnpm -C apps/desktop test",
    "tauri": "tauri"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "autoprefixer": "^10.4.20",
    "tailwindcss": "^3.4.17",
    "yaml": "^2.8.1"
  }
}
