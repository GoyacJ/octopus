{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TeamMemberJoinedEvent",
  "type": "object",
  "required": [
    "agent_id",
    "joined_at",
    "role",
    "session_id",
    "spec_hash",
    "spec_snapshot_id",
    "team_id",
    "visibility"
  ],
  "properties": {
    "agent_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "joined_at": {
      "type": "string",
      "format": "date-time"
    },
    "role": {
      "type": "string"
    },
    "session_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "spec_hash": {
      "type": "array",
      "items": {
        "type": "integer",
        "format": "uint8",
        "minimum": 0.0
      },
      "maxItems": 32,
      "minItems": 32
    },
    "spec_snapshot_id": {
      "$ref": "#/definitions/BlobRef"
    },
    "team_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "visibility": {
      "$ref": "#/definitions/ContextVisibility"
    }
  },
  "definitions": {
    "BlobRef": {
      "type": "object",
      "required": [
        "content_hash",
        "id",
        "size"
      ],
      "properties": {
        "content_hash": {
          "type": "array",
          "items": {
            "type": "integer",
            "format": "uint8",
            "minimum": 0.0
          },
          "maxItems": 32,
          "minItems": 32
        },
        "content_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "$ref": "#/definitions/TypedUlid"
        },
        "size": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "ContextVisibility": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "all",
            "private"
          ]
        },
        {
          "type": "object",
          "required": [
            "allowlist"
          ],
          "properties": {
            "allowlist": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/TypedUlid"
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "allowlist_quote"
          ],
          "properties": {
            "allowlist_quote": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/TypedUlid"
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
