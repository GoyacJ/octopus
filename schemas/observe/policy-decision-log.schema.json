{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/observe/policy-decision-log.schema.json",
  "title": "PolicyDecisionLog",
  "type": "object",
  "description": "Slice 2 shared contract for persisted governance decisions emitted before execution or approval-driven resume/block behavior.",
  "properties": {
    "id": { "type": "string" },
    "workspace_id": { "type": "string" },
    "project_id": { "type": "string" },
    "run_id": { "type": "string" },
    "task_id": { "type": "string" },
    "capability_id": { "type": "string" },
    "decision": {
      "type": "string",
      "enum": ["allow", "require_approval", "deny"]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "estimated_cost": {
      "type": "integer",
      "minimum": 0
    },
    "approval_request_id": {
      "type": ["string", "null"]
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "required": [
    "id",
    "workspace_id",
    "project_id",
    "run_id",
    "task_id",
    "capability_id",
    "decision",
    "reason",
    "estimated_cost",
    "created_at"
  ],
  "additionalProperties": false
}
