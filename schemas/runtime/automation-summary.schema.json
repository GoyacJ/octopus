{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/runtime/automation-summary.schema.json",
  "title": "AutomationSummary",
  "type": "object",
  "description": "Minimum GA automation summary contract composed from the existing automation, trigger, recent delivery, and run summary truth.",
  "properties": {
    "automation": {
      "$ref": "https://octopus.local/schemas/runtime/automation.schema.json"
    },
    "trigger": {
      "$ref": "https://octopus.local/schemas/runtime/trigger.schema.json"
    },
    "recent_deliveries": {
      "type": "array",
      "items": {
        "$ref": "https://octopus.local/schemas/runtime/trigger-delivery.schema.json"
      }
    },
    "last_run_summary": {
      "oneOf": [
        {
          "$ref": "https://octopus.local/schemas/runtime/run-summary.schema.json"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "required": ["automation", "trigger", "recent_deliveries", "last_run_summary"],
  "additionalProperties": false
}
