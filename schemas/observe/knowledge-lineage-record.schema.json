{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/observe/knowledge-lineage-record.schema.json",
  "title": "KnowledgeLineageRecord",
  "type": "object",
  "description": "GA foundation placeholder shared contract for knowledge lineage records.",
  "properties": {
    "id": { "type": "string" },
    "source_ref": { "type": "string" },
    "target_ref": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "required": ["id", "source_ref", "target_ref"],
  "additionalProperties": true
}
