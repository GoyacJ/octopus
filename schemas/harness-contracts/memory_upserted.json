{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MemoryUpsertedEvent",
  "type": "object",
  "required": [
    "action",
    "at",
    "bytes_written",
    "content_hash",
    "kind",
    "memory_id",
    "provider_id",
    "session_id",
    "source",
    "takes_effect",
    "visibility"
  ],
  "properties": {
    "action": {
      "$ref": "#/definitions/MemoryWriteAction"
    },
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "bytes_written": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "content_hash": {
      "$ref": "#/definitions/ContentHash"
    },
    "kind": {
      "$ref": "#/definitions/MemoryKind"
    },
    "memory_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "provider_id": {
      "type": "string"
    },
    "run_id": {
      "anyOf": [
        {
          "$ref": "#/definitions/TypedUlid"
        },
        {
          "type": "null"
        }
      ]
    },
    "session_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "source": {
      "$ref": "#/definitions/MemorySource"
    },
    "takes_effect": {
      "$ref": "#/definitions/TakesEffect"
    },
    "visibility": {
      "$ref": "#/definitions/MemoryVisibility"
    }
  },
  "definitions": {
    "ContentHash": {
      "type": "array",
      "items": {
        "type": "integer",
        "format": "uint8",
        "minimum": 0.0
      },
      "maxItems": 32,
      "minItems": 32
    },
    "MemoryKind": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "user_preference",
            "feedback",
            "project_fact",
            "reference",
            "agent_self_note"
          ]
        },
        {
          "type": "object",
          "required": [
            "custom"
          ],
          "properties": {
            "custom": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "MemorySource": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "user_input",
            "agent_derived",
            "external_retrieval",
            "imported"
          ]
        },
        {
          "type": "object",
          "required": [
            "subagent_derived"
          ],
          "properties": {
            "subagent_derived": {
              "type": "object",
              "required": [
                "child_session"
              ],
              "properties": {
                "child_session": {
                  "$ref": "#/definitions/TypedUlid"
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "consolidated"
          ],
          "properties": {
            "consolidated": {
              "type": "object",
              "required": [
                "from"
              ],
              "properties": {
                "from": {
                  "type": "array",
                  "items": {
                    "$ref": "#/definitions/TypedUlid"
                  }
                }
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "MemoryVisibility": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "tenant"
          ]
        },
        {
          "type": "object",
          "required": [
            "private"
          ],
          "properties": {
            "private": {
              "type": "object",
              "required": [
                "session_id"
              ],
              "properties": {
                "session_id": {
                  "$ref": "#/definitions/TypedUlid"
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "user"
          ],
          "properties": {
            "user": {
              "type": "object",
              "required": [
                "user_id"
              ],
              "properties": {
                "user_id": {
                  "type": "string"
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "team"
          ],
          "properties": {
            "team": {
              "type": "object",
              "required": [
                "team_id"
              ],
              "properties": {
                "team_id": {
                  "$ref": "#/definitions/TypedUlid"
                }
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "MemoryWriteAction": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "upsert",
            "forget"
          ]
        },
        {
          "type": "object",
          "required": [
            "append_section"
          ],
          "properties": {
            "append_section": {
              "type": "object",
              "required": [
                "section"
              ],
              "properties": {
                "section": {
                  "type": "string"
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "replace_section"
          ],
          "properties": {
            "replace_section": {
              "type": "object",
              "required": [
                "section"
              ],
              "properties": {
                "section": {
                  "type": "string"
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "delete_section"
          ],
          "properties": {
            "delete_section": {
              "type": "object",
              "required": [
                "section"
              ],
              "properties": {
                "section": {
                  "type": "string"
                }
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "TakesEffect": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "current_session",
            "next_session"
          ]
        },
        {
          "type": "object",
          "required": [
            "after_reload_with"
          ],
          "properties": {
            "after_reload_with": {
              "type": "object",
              "required": [
                "session_id"
              ],
              "properties": {
                "session_id": {
                  "$ref": "#/definitions/TypedUlid"
                }
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
