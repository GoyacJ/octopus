{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MemoryRecallDegradedEvent",
  "type": "object",
  "required": [
    "at",
    "provider_id",
    "reason",
    "run_id",
    "session_id",
    "turn"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "provider_id": {
      "type": "string"
    },
    "reason": {
      "$ref": "#/definitions/MemoryRecallDegradedReason"
    },
    "run_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "session_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "turn": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    }
  },
  "definitions": {
    "MemoryRecallDegradedReason": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "timeout",
            "record_too_large",
            "visibility_violation",
            "scanner_blocked"
          ]
        },
        {
          "type": "object",
          "required": [
            "provider_error"
          ],
          "properties": {
            "provider_error": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
