{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TeamMemberLeftEvent",
  "type": "object",
  "required": [
    "agent_id",
    "left_at",
    "reason",
    "team_id"
  ],
  "properties": {
    "agent_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "left_at": {
      "type": "string",
      "format": "date-time"
    },
    "reason": {
      "$ref": "#/definitions/MemberLeaveReason"
    },
    "team_id": {
      "$ref": "#/definitions/TypedUlid"
    }
  },
  "definitions": {
    "MemberLeaveReason": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "goal_achieved",
            "quota_exceeded",
            "interrupted",
            "removed",
            "stalled_removed"
          ]
        },
        {
          "type": "object",
          "required": [
            "error"
          ],
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
