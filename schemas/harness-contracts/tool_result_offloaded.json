{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ToolResultOffloadedEvent",
  "type": "object",
  "required": [
    "at",
    "blob_ref",
    "effective_limit",
    "head_chars",
    "original_metric",
    "original_size",
    "run_id",
    "tail_chars",
    "tool_use_id"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "blob_ref": {
      "$ref": "#/definitions/BlobRef"
    },
    "effective_limit": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "head_chars": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "original_metric": {
      "$ref": "#/definitions/BudgetMetric"
    },
    "original_size": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "run_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "tail_chars": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "tool_use_id": {
      "$ref": "#/definitions/TypedUlid"
    }
  },
  "definitions": {
    "BlobRef": {
      "type": "object",
      "required": [
        "content_hash",
        "id",
        "size"
      ],
      "properties": {
        "content_hash": {
          "type": "array",
          "items": {
            "type": "integer",
            "format": "uint8",
            "minimum": 0.0
          },
          "maxItems": 32,
          "minItems": 32
        },
        "content_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "$ref": "#/definitions/TypedUlid"
        },
        "size": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "BudgetMetric": {
      "type": "string",
      "enum": [
        "chars",
        "bytes",
        "lines"
      ]
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
