{
  "name": "octopus-workspace",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build:web": "pnpm --filter @octopus/client build",
    "typecheck:web": "pnpm --filter @octopus/contracts typecheck && pnpm --filter @octopus/client typecheck",
    "test:web": "pnpm --filter @octopus/contracts test && pnpm --filter @octopus/client test",
    "build:hub": "cargo build --workspace",
    "test:hub": "cargo test --workspace",
    "verify": "pnpm run typecheck:web && pnpm run test:web && pnpm run build:web && cargo test --workspace && cargo build --workspace"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.3",
    "unocss": "^66.5.4",
    "vite": "^7.1.12",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.1.1"
  }
}
