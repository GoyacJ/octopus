{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EngineFailedEvent",
  "type": "object",
  "required": [
    "at",
    "error"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "error": {
      "$ref": "#/definitions/EngineError"
    },
    "run_id": {
      "anyOf": [
        {
          "$ref": "#/definitions/TypedUlid"
        },
        {
          "type": "null"
        }
      ]
    },
    "session_id": {
      "anyOf": [
        {
          "$ref": "#/definitions/TypedUlid"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "definitions": {
    "EngineError": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "message"
          ],
          "properties": {
            "message": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
