{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ToolUseHeartbeatEvent",
  "type": "object",
  "required": [
    "at",
    "message",
    "run_id",
    "silent_for_ms",
    "tool_use_id"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "fraction": {
      "type": [
        "number",
        "null"
      ],
      "format": "float"
    },
    "message": {
      "type": "string"
    },
    "run_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "silent_for_ms": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "tool_use_id": {
      "$ref": "#/definitions/TypedUlid"
    }
  },
  "definitions": {
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
