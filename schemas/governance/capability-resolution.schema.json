{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/governance/capability-resolution.schema.json",
  "title": "CapabilityResolution",
  "type": "object",
  "description": "GA minimum-surface shared contract that explains whether a project-bound capability will execute immediately, require approval, or be denied for the current estimated cost.",
  "properties": {
    "descriptor": {
      "$ref": "https://octopus.local/schemas/governance/capability-descriptor.schema.json"
    },
    "scope_ref": {
      "type": "string",
      "minLength": 1
    },
    "execution_state": {
      "type": "string",
      "enum": ["executable", "approval_required", "denied"]
    },
    "reason_code": {
      "type": "string",
      "enum": [
        "capability_not_registered",
        "capability_not_bound",
        "capability_not_granted",
        "budget_policy_missing",
        "budget_hard_limit_exceeded",
        "risk_level_high",
        "budget_soft_limit_exceeded",
        "within_budget"
      ]
    },
    "explanation": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "descriptor",
    "scope_ref",
    "execution_state",
    "reason_code",
    "explanation"
  ],
  "additionalProperties": false
}
