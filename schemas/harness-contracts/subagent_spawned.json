{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SubagentSpawnedEvent",
  "type": "object",
  "required": [
    "agent_ref",
    "at",
    "depth",
    "parent_run_id",
    "parent_session_id",
    "spec_hash",
    "spec_snapshot_id",
    "subagent_id"
  ],
  "properties": {
    "agent_ref": {
      "$ref": "#/definitions/AgentRef"
    },
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "depth": {
      "type": "integer",
      "format": "uint8",
      "minimum": 0.0
    },
    "parent_run_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "parent_session_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "spec_hash": {
      "type": "array",
      "items": {
        "type": "integer",
        "format": "uint8",
        "minimum": 0.0
      },
      "maxItems": 32,
      "minItems": 32
    },
    "spec_snapshot_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "subagent_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "trigger_tool_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "trigger_tool_use_id": {
      "anyOf": [
        {
          "$ref": "#/definitions/TypedUlid"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "definitions": {
    "AgentRef": {
      "type": "object",
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "$ref": "#/definitions/TypedUlid"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    }
  }
}
