{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GraceCallTriggeredEvent",
  "type": "object",
  "required": [
    "at",
    "current_iteration",
    "max_iterations",
    "run_id",
    "usage_snapshot"
  ],
  "properties": {
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "correlation_id": {
      "default": "01KQ2T01KT8NVTN31XWWEA8DN2",
      "allOf": [
        {
          "$ref": "#/definitions/TypedUlid"
        }
      ]
    },
    "current_iteration": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "max_iterations": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "run_id": {
      "$ref": "#/definitions/TypedUlid"
    },
    "session_id": {
      "default": "01KQ2T01KT0FRWXKS6Q6MP2ZPD",
      "allOf": [
        {
          "$ref": "#/definitions/TypedUlid"
        }
      ]
    },
    "tenant_id": {
      "default": "00000000000000000000000001",
      "allOf": [
        {
          "$ref": "#/definitions/TypedUlid"
        }
      ]
    },
    "usage_snapshot": {
      "$ref": "#/definitions/UsageSnapshot"
    }
  },
  "definitions": {
    "TypedUlid": {
      "type": "string",
      "format": "ulid"
    },
    "UsageSnapshot": {
      "type": "object",
      "required": [
        "cache_read_tokens",
        "cache_write_tokens",
        "cost_micros",
        "input_tokens",
        "output_tokens"
      ],
      "properties": {
        "cache_read_tokens": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "cache_write_tokens": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "cost_micros": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "input_tokens": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "output_tokens": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    }
  }
}
